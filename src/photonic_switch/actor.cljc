(defn create-switch-fabric
  "Create a SwitchFabric."
  [port data]
  (require-fields data ["name" "radix"])
  (let [id (new-id "psw_swi")
        e {:db/id id
           :photonic_switch.SwitchFabric/id id
           :photonic_switch.SwitchFabric/name (get data :name)
           :photonic_switch.SwitchFabric/radix (as-long (get data :radix))
           :photonic_switch.SwitchFabric/technology (get data :technology)
           :photonic_switch.SwitchFabric/switchingTimeNs (as-double (get data :switchingTimeNs))
           :photonic_switch.SwitchFabric/createdAt (now)
           :photonic_switch.SwitchFabric/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-switch-fabrics
  "List SwitchFabric with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-switch-fabrics port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :photonic_switch.SwitchFabric/id))
         rows (apply-filters rows (:filter opts) [:photonic_switch.SwitchFabric/name :photonic_switch.SwitchFabric/radix :photonic_switch.SwitchFabric/technology :photonic_switch.SwitchFabric/switchingTimeNs])]
     (paginate rows opts))))

(defn get-switch-fabric
  "Retrieve a SwitchFabric by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-switch-fabric port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-switch-fabric
  "Update a SwitchFabric; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :name) (conj [:db/add id :photonic_switch.SwitchFabric/name (get data :name)]))
                   (cond-> (contains? data :radix) (conj [:db/add id :photonic_switch.SwitchFabric/radix (as-long (get data :radix))]))
                   (cond-> (contains? data :technology) (conj [:db/add id :photonic_switch.SwitchFabric/technology (get data :technology)]))
                   (cond-> (contains? data :switchingTimeNs) (conj [:db/add id :photonic_switch.SwitchFabric/switchingTimeNs (as-double (get data :switchingTimeNs))]))
                   (conj [:db/add id :photonic_switch.SwitchFabric/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-switch-fabric
  "Delete a SwitchFabric."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

