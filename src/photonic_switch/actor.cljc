;; collection → CRUD fns, keyed by the /v1/<collection> path segment
(def ^:private handlers
  {"switchfabrics" {:create create-switch-fabric :list list-switch-fabrics :get get-switch-fabric :update update-switch-fabric :delete delete-switch-fabric}
   "opticalports" {:create create-optical-port :list list-optical-ports :get get-optical-port :update update-optical-port :delete delete-optical-port}
   "waveguidecrosses" {:create create-waveguide-cross :list list-waveguide-crosses :get get-waveguide-cross :update update-waveguide-cross :delete delete-waveguide-cross}
   "memsmirrors" {:create create-mems-mirror :list list-mems-mirrors :get get-mems-mirror :update update-mems-mirror :delete delete-mems-mirror}
   "routepaths" {:create create-route-path :list list-route-paths :get get-route-path :update update-route-path :delete delete-route-path}
   "lossbudgets" {:create create-loss-budget :list list-loss-budgets :get get-loss-budget :update update-loss-budget :delete delete-loss-budget}})

(defn- expand-opts [params]
  (when-let [x (:expand params)]
    {:expand (set (map keyword (str/split (str x) #",")))}))

(defn dispatch
  "Route an HTTP-ish request through `routes` to the CRUD fns.
   req: {:method (:get/:post/:patch/:delete) :path /v1/<coll>[/<id>] :params {} :body {}}.
   Returns {:status int :body any} — the runnable L4 service surface."
  [port {:keys [method path params body]}]
  (let [segs (->> (str/split (or path "") #"/") (remove str/blank?) vec)
        coll (get segs 1)
        id   (get segs 2)
        h    (get handlers coll)
        params (or params {})]
    (cond
      (nil? h) {:status 404 :body {:error "unknown collection"}}
      (and (= method :post) (nil? id)) {:status 201 :body ((:create h) port (or body params))}
      (and (= method :get) (nil? id)) {:status 200 :body ((:list h) port params)}
      (and (= method :get) id) (if-let [r ((:get h) port id (expand-opts params))]
                                 {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (#{:patch :put} method) id) (if-let [r ((:update h) port id (or body params))]
                                         {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (= method :delete) id) {:status 200 :body ((:delete h) port id)}
      :else {:status 405 :body {:error "method not allowed"}})))

