                   (conj [:db/add id :photonic_switch.RoutePath/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-route-path
  "Delete a RoutePath."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

;; ── LossBudget ────────────────────────────────────────────────────────────────
(defn create-loss-budget
  "Create a LossBudget."
  [port data]
  (require-fields data ["insertionLossDb" "crosstalkDb"])
  (let [id (new-id "psw_los")
        e {:db/id id
           :photonic_switch.LossBudget/id id
           :photonic_switch.LossBudget/fabricId (get data :fabricId)
           :photonic_switch.LossBudget/insertionLossDb (as-double (get data :insertionLossDb))
           :photonic_switch.LossBudget/crosstalkDb (as-double (get data :crosstalkDb))
           :photonic_switch.LossBudget/marginDb (as-double (get data :marginDb))
           :photonic_switch.LossBudget/createdAt (now)
           :photonic_switch.LossBudget/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-loss-budgets
  "List LossBudget with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-loss-budgets port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :photonic_switch.LossBudget/id))
         rows (apply-filters rows (:filter opts) [:photonic_switch.LossBudget/fabricId :photonic_switch.LossBudget/insertionLossDb :photonic_switch.LossBudget/crosstalkDb :photonic_switch.LossBudget/marginDb])]
     (paginate rows opts))))

(defn get-loss-budget
  "Retrieve a LossBudget by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-loss-budget port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-loss-budget
  "Update a LossBudget; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :fabricId) (conj [:db/add id :photonic_switch.LossBudget/fabricId (get data :fabricId)]))
                   (cond-> (contains? data :insertionLossDb) (conj [:db/add id :photonic_switch.LossBudget/insertionLossDb (as-double (get data :insertionLossDb))]))
                   (cond-> (contains? data :crosstalkDb) (conj [:db/add id :photonic_switch.LossBudget/crosstalkDb (as-double (get data :crosstalkDb))]))
                   (cond-> (contains? data :marginDb) (conj [:db/add id :photonic_switch.LossBudget/marginDb (as-double (get data :marginDb))]))
                   (conj [:db/add id :photonic_switch.LossBudget/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-loss-budget
  "Delete a LossBudget."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

